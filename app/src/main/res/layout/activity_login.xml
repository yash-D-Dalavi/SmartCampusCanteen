<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- TOP HERO — Orange header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="#FF6B35"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍽️"
            android:textSize="64sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campus Canteen"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time Kitchen Sync"
            android:textColor="#FFE0CC"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ROLE TABS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#FFFFFF"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_student_login"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🎓 Student"
            android:textColor="#FF6B35"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/tab_active_indicator"/>

        <TextView
            android:id="@+id/tab_staff_login"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👨‍🍳 Staff"
            android:textColor="#999999"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- SCROLL — dono panels -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- ===== STUDENT PANEL ===== -->
            <LinearLayout
                android:id="@+id/panel_student"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome, Student!"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in with your Google account to order food"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="28dp"/>

                <!-- Google Sign-In Button -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/btn_google_signin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="G"
                            android:textColor="#4285F4"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  Sign in with Google"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- OR divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#EEEEEE"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  OR  " android:textColor="#AAAAAA" android:textSize="12sp"/>
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#EEEEEE"/>
                </LinearLayout>

                <!-- Guest / Name login -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue as Guest"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/et_guest_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Enter your name"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:textColorHint="#AAAAAA"
                    android:inputType="textPersonName"/>

                <Button
                    android:id="@+id/btn_guest_login"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_orange_rounded"
                    android:text="Continue as Guest →"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ===== STAFF PANEL — pehle hidden ===== -->
            <LinearLayout
                android:id="@+id/panel_staff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Staff Login"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select your role and enter password"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Role selection — Kitchen ya Counter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Kitchen Card -->
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:id="@+id/card_role_kitchen"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#EDE7F6">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍳" android:textSize="24sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kitchen" android:textColor="#4527A0"
                                android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Counter Card -->
                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:id="@+id/card_role_counter"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFF3E0">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏪" android:textSize="24sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Counter" android:textColor="#E65100"
                                android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Selected role display -->
                <TextView
                    android:id="@+id/tv_selected_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👆 Upar se role select karo"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- Password field -->
                <EditText
                    android:id="@+id/et_staff_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="Enter staff password"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:textColor="#212121"
                    android:textColorHint="#AAAAAA"/>

                <!-- Login Button -->
                <Button
                    android:id="@+id/btn_staff_login"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_orange_rounded"
                    android:text="Login →"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- Password hint -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔑 Kitchen: kitchen123  |  Counter: counter123"
                    android:textColor="#BBBBBB"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SPM Lab Project • Yash Dalavi • PRN: 202301100017"
        android:textColor="#CCCCCC"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"/>

</LinearLayout>