<?xml version="1.0" encoding="utf-8"?>
<!-- Counter par dikhne wala ek order ka card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Left: Token circle -->
        <TextView
            android:id="@+id/tv_token"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="#101"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/token_circle_bg"/>

        <!-- Middle: Order details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yash"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_order_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Samosa x1 • ₹15"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <!-- Status chip -->
            <TextView
                android:id="@+id/tv_order_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Received"
                android:textColor="#F39C12"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Right: Mark Ready button -->
        <Button
            android:id="@+id/btn_mark_ready"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark Ready"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/btn_green_rounded"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>