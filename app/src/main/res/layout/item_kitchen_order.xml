<?xml version="1.0" encoding="utf-8"?>
<!-- Kitchen staff ke liye incoming order ka card — bade buttons -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#1E2A3A"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: Token + Item name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Big Token Badge -->
            <TextView
                android:id="@+id/tv_kitchen_token"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="#101"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/token_circle_bg"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp">

                <TextView
                    android:id="@+id/tv_kitchen_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Samosa x1"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_kitchen_student"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student: Yash"
                    android:textColor="#AAAACC"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- NEW Order badge — sirf "Received" orders par -->
            <TextView
                android:id="@+id/tv_new_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_new_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Bottom: Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:gravity="end">

            <!-- "Start Preparing" Button — BIG aur easy to tap -->
            <Button
                android:id="@+id/btn_start_preparing"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_blue_rounded"
                android:text="▶ START PREPARING"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <!-- "Done / Ready" Button -->
            <Button
                android:id="@+id/btn_mark_done"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/btn_green_rounded"
                android:text="✓ READY"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>