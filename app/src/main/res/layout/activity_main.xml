<?xml version="1.0" encoding="utf-8"?>
<!-- Yeh poori app ka pehla screen hai — role selection -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- ===== TOP HERO SECTION ===== -->
    <!-- Orange gradient jaisa feel — solid background se banaya -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#FF6B35"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="20dp">

        <!-- App Logo Emoji — bada dikhega -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍽️"
            android:textSize="64sp"/>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campus Canteen"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time Kitchen Sync System"
            android:textColor="#FFE0CC"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ===== MIDDLE: ROLE SELECT LABEL ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SELECT YOUR ROLE"
        android:textColor="#999999"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="12dp"/>

    <!-- ===== 3 ROLE BUTTONS ===== -->
    <!-- ScrollView — chhoti screen par bhi sab dikhe -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BUTTON 1: Student -->
            <!-- CardView use kiya — Swiggy jaisi shadow aur rounded look -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/card_student"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <!-- Left: colored circle with emoji -->
                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="🎓"
                        android:textSize="26sp"
                        android:background="@drawable/circle_teal"/>

                    <!-- Middle: title + subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="I am a Student"
                            android:textColor="#212121"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Browse menu, place order, track token"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- Right: arrow -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#CCCCCC"
                        android:textSize="28sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BUTTON 2: Kitchen Staff -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/card_kitchen"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="🍳"
                        android:textSize="26sp"
                        android:background="@drawable/circle_purple"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kitchen Staff"
                            android:textColor="#212121"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toggle availability, prepare orders"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#CCCCCC"
                        android:textSize="28sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BUTTON 3: Counter Manager -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/card_counter"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="🏪"
                        android:textSize="26sp"
                        android:background="@drawable/circle_orange"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Counter Manager"
                            android:textColor="#212121"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View orders, verify payment, mark ready"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#CCCCCC"
                        android:textSize="28sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ===== FOOTER ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SPM Lab Project • Yash Dalavi • PRN: 202301100017"
        android:textColor="#BBBBBB"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"/>

</LinearLayout>